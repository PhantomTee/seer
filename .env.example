# =============================================================
# ArcPredict - Environment Variables
# Copy to .env.local or run pnpm setup.
# Leave private values empty in source control.
# =============================================================

# -- Arc Testnet ------------------------------------------------
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_WS_URL=wss://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_EXPLORER=https://testnet.arcscan.app

# -- Deployer Wallet (AUTO-GENERATED by pnpm setup) ------------
DEPLOYER_ADDRESS=
DEPLOYER_PRIVATE_KEY=
DEPLOYER_MNEMONIC=

# -- Agent Wallet (AUTO-GENERATED by pnpm setup) ---------------
AGENT_ADDRESS=
AGENT_PRIVATE_KEY=
AGENT_MNEMONIC=


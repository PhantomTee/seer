{
  "name": "arcpredict",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "contracts:install": "cd contracts && forge install OpenZeppelin/openzeppelin-contracts@v5.2.0 && forge install smartcontractkit/chainlink",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vvv",
    "contracts:gas": "cd contracts && forge test -vvv --gas-report",
    "contracts:deploy": "cd contracts && forge script script/Deploy.s.sol --rpc-url $NEXT_PUBLIC_ARC_RPC_URL --private-key $DEPLOYER_PRIVATE_KEY --broadcast",
    "contracts:verify": "cd contracts && forge verify-contract --chain-id 5042002",
    "supabase:types": "supabase gen types typescript --local > types/supabase.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@fairblock/stabletrust": "latest",
    "@lifi/sdk": "latest",
    "@lifi/widget": "latest",
    "@mysten/sui": "2.16.3",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "^2.75.0",
    "@tanstack/react-query": "latest",
    "ethers": "^6.15.0",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "next": "15.5.18",
    "pino-pretty": "^13.1.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "latest",
    "viem": "^2.38.0",
    "wagmi": "^2.18.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.22",
    "eslint": "latest",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "overrides": {
      "@mysten/sui": "2.16.3"
    },
    "onlyBuiltDependencies": [
      "bufferutil",
      "esbuild",
      "keccak",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ]
  }
}
